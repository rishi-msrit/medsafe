# Environment variables for MedSafe
# Copy this file to .env and fill in the values

# ─── API Server ───────────────────────────────────────────────────────────────
MEDSAFE_HOST=0.0.0.0
MEDSAFE_PORT=8000

# ─── Frontend Dev Server ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── DrugBank (place full_database.xml in this path) ──────────────────────────
DRUGBANK_XML_PATH=data/raw/drugbank_full_database.xml

# ─── MLflow Tracking ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=medsafe_training

# ─── CUDA ─────────────────────────────────────────────────────────────────────
# Set to "cpu" to force CPU mode even if CUDA is available
MEDSAFE_DEVICE=auto
